# ==============================================================================
# NIGHA RADAR - COMMON ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================
# This is the single, unified configuration template for the entire repository.
# Copy this file to '.env' in the root directory.
#
# Since the frontend and backend are deployed within a single repository,
# both components can share or read from this unified configuration.
# ==============================================================================

# ------------------------------------------------------------------------------
# SECTION 1: NestJS BACKEND CONFIGURATION
# ------------------------------------------------------------------------------

# Port on which the NestJS backend server will listen.
# Referenced in: backend/src/main.ts
# Default fallback: 5000
PORT=5000

# MongoDB connection URI.
# Referenced in: backend/src/app.module.ts
# Default fallback: mongodb://127.0.0.1:27017/nigha-chute
MONGODB_URI=mongodb://127.0.0.1:27017/nigha-chute

# Secret key used to sign and verify JWT tokens.
# Referenced in: backend/src/auth/jwt.strategy.ts, backend/src/auth/auth.module.ts
# Default fallback: nigha-radar-secret-key-12345
# WARNING: Change this to a strong, random, 256-bit key in production.
JWT_SECRET=nigha-radar-secret-key-12345

# Comma-separated list of origins allowed to make CORS requests.
# Referenced in: backend/src/main.ts
# Default fallback: http://localhost:5173,http://localhost:4173
CORS_WHITELIST=http://localhost:5173,http://localhost:4173

# Node environment. Used to bypass telemetry logging in tests.
# Referenced in: backend/src/industry/industry.service.ts
# Default fallback: None
NODE_ENV=development

# MQTT Broker connection URL.
# Referenced in: backend/src/mqtt/mqtt.service.ts, simulator/index.js
# Default fallback: mqtts://g292ae11.ala.asia-southeast1.emqxsl.com:8883
MQTT_BROKER_URL=mqtts://g292ae11.ala.asia-southeast1.emqxsl.com:8883

# Dedicated MQTT credentials for the NestJS Backend API service.
# Referenced in: backend/src/mqtt/mqtt.service.ts
# Default fallback: pf086f1d
MQTT_BACKEND_USERNAME=pf086f1d
MQTT_BACKEND_PASSWORD=PrE_6sIGv9Efa0zQ

# Dedicated MQTT credentials for the Telemetry Simulator (IoT Gateway).
# Referenced in: simulator/index.js
# Default fallback: pf086f1d
MQTT_SIMULATOR_USERNAME=pf086f1d
MQTT_SIMULATOR_PASSWORD=PrE_6sIGv9Efa0zQ

# OpenAI API key for AI Copilot chat and predictive insights.
# Referenced in: backend/src/ai/ai.service.ts
# Default fallback: None (falls back to offline rule engine if missing)
OPENAI_API_KEY=

# Anthropic API key for AI Copilot chat and predictive insights.
# Referenced in: backend/src/ai/ai.service.ts
# Default fallback: None (falls back to offline rule engine if missing)
ANTHROPIC_API_KEY=

# Testing/Demo Backdoor OTP
# Default fallback: 778899
DEMO_OTP=778899

# ------------------------------------------------------------------------------
# SECTION 2: Vite FRONTEND CONFIGURATION
# ------------------------------------------------------------------------------
# Note: The frontend codebase currently does not reference any environment 
# variables (all API calls are hardcoded to 'http://localhost:5000').
#
# If the frontend is refactored to support dynamic parameterization in Vite,
# it will load variables prefixed with 'VITE_'.
# Recommended variable:
VITE_API_URL=http://localhost:5000
